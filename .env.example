# =============================================================
# LLM
# =============================================================
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# =============================================================
# Gmail
# =============================================================
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
EMAIL_BODY_MAX_CHARS=3000

# =============================================================
# Chunking e análise
# =============================================================
CHUNK_SIZE=10
MIN_CONFIDENCE=0.5
MAX_RETRIES=2

# =============================================================
# Filtros de saída (valores separados por vírgula)
# FILTER_CATEGORIES     — categorias a EXCLUIR do digest
# FILTER_MIN_PRIORITY   — prioridade mínima para incluir (LOW = tudo)
# FILTER_REQUIRES_ACTION/RESPONSE=true — inclui APENAS e-mails que requerem ação/resposta
# =============================================================
FILTER_CATEGORIES=SPAM,MARKETING
FILTER_MIN_PRIORITY=LOW
FILTER_REQUIRES_ACTION=false
FILTER_REQUIRES_RESPONSE=false

# =============================================================
# Agendamento (formato cron: minuto hora dia mês dia_semana)
# =============================================================
SCHEDULE_CRON=0 7 * * *
SCHEDULE_TIMEZONE=America/Sao_Paulo

# Janela de coleta usada apenas na primeira execução (sem last_run.json)
COLLECTION_WINDOW_HOURS=24

# =============================================================
# WhatsApp — Evolution API
# =============================================================
EVOLUTION_URL=http://localhost:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
WHATSAPP_TARGET_NUMBER=
WHATSAPP_MAX_CHARS=4096

# =============================================================
# Fallback — SMTP
# =============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FALLBACK_EMAIL_TO=
